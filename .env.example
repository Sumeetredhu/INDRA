# INDRA configuration. Copy to `.env` and fill in what you have.
#
# Every value below has a working default. INDRA boots, ingests, answers, alerts and audits with
# this file completely empty — it just uses in-memory stores and the deterministic stub LLM.
# Fill these in to move from "runs anywhere" to "runs for real".

# ---------------------------------------------------------------- application
INDRA_ENVIRONMENT=local            # local | demo | production | test
INDRA_DEBUG=false
INDRA_LOG_LEVEL=INFO
INDRA_LOG_JSON=false               # true in Docker, so `docker logs | jq` works
INDRA_API_PORT=8000

# Deterministic mode: seeded stub LLM, fixed timestamps, no live network.
# Turn this ON for the recorded demo — it makes every run byte-identical.
INDRA_DEMO_MODE=false
INDRA_OFFLINE_MODE=false

# ---------------------------------------------------------------- storage
# auto     probe real backends, fall back to memory per-store  (recommended)
# external require Neo4j/Chroma/Redis; fail loudly if absent
# memory   never touch a container                             (fastest to run)
INDRA_STORAGE_BACKEND=auto

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=indra_dev_password

REDIS_URL=redis://localhost:6379/0

# SQLite by default (D10). In Docker: postgresql+asyncpg://indra:indra@postgres:5432/indra
# DATABASE_URL=

# ---------------------------------------------------------------- LLM providers
# Free tier: https://aistudio.google.com/apikey  — 1,500 embed req/day, ~500 generations/day
GEMINI_API_KEY=

# Fast fallback, generous free tier: https://console.groq.com/keys
GROQ_API_KEY=

# Optional additional provider (D2)
# ANTHROPIC_API_KEY=

# Ordered failover chain. `stub` is always last and always works.
INDRA_LLM_PROVIDER_CHAIN=gemini,groq,ollama,stub
INDRA_EMBEDDING_PROVIDER_CHAIN=gemini,local,hash

INDRA_GEMINI_CHAT_MODEL=gemini-2.5-flash
INDRA_GEMINI_EMBEDDING_MODEL=text-embedding-004
INDRA_GEMINI_DAILY_BUDGET=450      # headroom under the ~500/day free tier

INDRA_OLLAMA_BASE_URL=http://localhost:11434
INDRA_OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# ---------------------------------------------------------------- ingestion
INDRA_MAX_UPLOAD_MB=50
INDRA_CHUNK_SIZE_TOKENS=384
INDRA_CHUNK_OVERLAP_TOKENS=50
INDRA_OCR_MIN_CONFIDENCE=0.55

# ---------------------------------------------------------------- P&ID vision (D4)
INDRA_PID_DETECTOR=rule_based      # rule_based | yolo | auto
# INDRA_PID_YOLO_WEIGHTS=./models/pid_yolov8.pt
INDRA_PID_TAG_FUZZY_THRESHOLD=82

# ---------------------------------------------------------------- retrieval (D3)
INDRA_FUSION_STRATEGY=weighted     # weighted | rrf
INDRA_RETRIEVAL_VECTOR_WEIGHT=0.6
INDRA_RETRIEVAL_GRAPH_WEIGHT=0.4   # must sum to 1.0 with the line above
INDRA_MAX_HOPS=3
INDRA_FINAL_TOP_K=10

# ---------------------------------------------------------------- proactive intelligence
INDRA_PRECURSOR_SIMILARITY_THRESHOLD=0.72
INDRA_OEM_THRESHOLD_WARNING_RATIO=0.85
INDRA_KNOWLEDGE_CLIFF_CRITICAL_SCORE=75
INDRA_PROACTIVE_SCAN_INTERVAL_S=900

# ---------------------------------------------------------------- mobile
INDRA_SUPPORTED_LANGUAGES=en,hi,ta,kn,mr
INDRA_WHISPER_MODEL=base
INDRA_OFFLINE_BUNDLE_MB=500

# ---------------------------------------------------------------- security
# Comma-separated. Leave EMPTY to disable auth — acceptable for local dev only.
INDRA_API_KEYS=
INDRA_RATE_LIMIT_PER_MINUTE=120
